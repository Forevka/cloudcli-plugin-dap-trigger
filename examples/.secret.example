# cloudcli-plugin-dap-trigger — secret/config template
#
# Copy to `<pluginDir>/.secret` and `chmod 600` it. The plugin reads this file
# once on startup (CloudCLI's plugin host strips most env vars, so file-backed
# config is necessary). Restart CloudCLI to pick up changes.
#
# Lines starting with `#` and blank lines are ignored.

# REQUIRED. HMAC-SHA256 shared secret. Both sides of the webhook hash bodies
# with this. Generate with: openssl rand -hex 32
DAP_WEBHOOK_SECRET=replace-me-with-a-real-64-hex-char-secret

# RECOMMENDED. Public URL of your CloudCLI host. Surfaced via the plugin's
# /api/config so the UI tab can display the canonical webhook URL. Trailing
# slash optional.
PUBLIC_BASE_URL=https://cloudcli.example.com

# OPTIONAL. Default git host for short-form `group/name` repo references in
# the webhook body. Leave unset to require callers to pass a full git URL
# (git@host:group/name.git or https://host/group/name.git).
# GIT_DEFAULT_HOST=gitlab.example.com

# OPTIONAL. Defaults below — override only if you need to.
# DAP_PLUGIN_PORT=3020
# WORKSPACES_ROOT=/home/repos
# CLAUDE_BIN=/usr/local/bin/claude
# RUN_TIMEOUT_MS=600000
